model User {
  id            String       @id @default(uuid())
  name          String       @db.VarChar(255)
  email         String       @unique
  password      String
  role          Role         @default(USER)
  active_status ActiveStatus @default(ACTIVE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  profile    Profile?

  comments Comment[]
  posts    Post[]

  @@map("users")
}
